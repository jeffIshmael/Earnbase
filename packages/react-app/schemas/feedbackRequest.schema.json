{
    "type": "object",
    "required": [
        "title",
        "description",
        "constraints",
        "subtasks"
    ],
    "properties": {
        "title": {
            "type": "string"
        },
        "description": {
            "type": "string",
            "description": "An explanation of the title of task"
        },
        "constraints": {
            "type": "object",
            "required": [
                "participants",
                "rewardPerParticipant"
            ],
            "properties": {
                "participants": {
                    "type": "integer",
                    "minimum": 1
                },
                "rewardPerParticipant": {
                    "type": "string",
                    "description": "USDC amount per contributor"
                },
                "countryRestriction": {
                    "type": "boolean"
                },
                "countries": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "ISO 3-letter country codes"
                },
                "ageRestriction": {
                    "type": "boolean"
                },
                "minAge": {
                    "type": "integer"
                },
                "maxAge": {
                    "type": "integer"
                },
                "genderRestriction": {
                    "type": "boolean"
                },
                "gender": {
                    "type": "string",
                    "enum": [
                        "M",
                        "F"
                    ]
                }
            }
        },
        "subtasks": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "prompt": {
                        "type": "string",
                        "description": "This is the prompt of what is needed from the human. More like the question itself"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "MULTIPLE_CHOICE",
                            "TEXT_INPUT",
                            "FILE_UPLOAD",
                            "CHOICE_SELECTION",
                            "RATING"
                        ]
                    },
                    "required": {
                        "type": "boolean"
                    },
                    "order": {
                        "type": "integer"
                    },
                    "options": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "fileTypes": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "Optional webhook endpoint for results"
        }
    }
}