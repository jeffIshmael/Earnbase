{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feedback Result",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "processing",
        "completed",
        "cancelled"
      ]
    },
    "requestId": {
      "type": "string"
    },
    "taskId": {
      "type": "integer"
    },
    "ipfsHash": {
      "type": "string"
    },
    "resultsUrl": {
      "type": "string",
      "format": "uri"
    },
    "summary": {
      "type": "object",
      "properties": {
        "participants": {
          "type": "integer"
        },
        "maxParticipants": {
          "type": "integer"
        },
        "completionRate": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "status",
    "requestId"
  ]
}